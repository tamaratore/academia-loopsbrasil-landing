---
import Base from '../layouts/Base.astro';
import RedeFooter from '../components/RedeFooter.astro';
import { cursos } from '../data/cursos';

export function getStaticPaths() {
  return cursos.map((c) => ({
    params: { slug: c.slug },
    props: { curso: c },
  }));
}

const { curso } = Astro.props;
const outrosCursos = cursos.filter((c) => c.slug !== curso.slug);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: curso.titulo,
  description: curso.descLonga,
  provider: {
    '@type': 'Organization',
    name: 'Academia Loops Brasil',
    sameAs: 'https://academia.loopsbrasil.com.br',
  },
};
---
<Base
  title={`${curso.titulo} | Academia Loops Brasil`}
  description={curso.desc}
  redeAtual="Academia Loops Brasil"
  academiaMode
  cursoAtualSlug={curso.slug}
  structuredData={structuredData}
>
  <main class="mx-auto flex w-full max-w-3xl flex-col items-center px-4 pb-20 pt-28 text-center sm:px-6 sm:pt-24">
    {curso.badge && (
      <span class="inline-block w-fit rounded-full bg-brand-red/20 px-3 py-1 text-[10px] font-semibold uppercase tracking-wide text-brand-red">
        {curso.badge}
      </span>
    )}
    <h1 class="balance mt-4 font-hero text-3xl uppercase leading-snug text-paper sm:text-4xl">
      {curso.titulo}
    </h1>
    <p class="mt-4 max-w-xl text-lg text-paper/70">
      {curso.desc}
    </p>

    <div class="video-facade media-card group relative mt-10 aspect-video w-full cursor-pointer overflow-hidden rounded-2xl bg-ink-raised" data-youtube-id={curso.videoId} tabindex="0" role="button" aria-label={`Assistir ao vídeo de ${curso.titulo}`}>
      <img
        src={`https://img.youtube.com/vi/${curso.videoId}/maxresdefault.jpg`}
        alt=""
        class="absolute inset-0 h-full w-full object-cover opacity-60 transition group-hover:opacity-75"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-black/35"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="video-play-btn flex h-16 w-16 items-center justify-center rounded-full bg-paper/95 shadow-xl ring-4 ring-black/20 sm:h-20 sm:w-20">
          <svg viewBox="0 0 24 24" class="ml-1 h-7 w-7 fill-ink sm:h-8 sm:w-8"><path d="M8 5v14l11-7z"></path></svg>
        </span>
      </div>
    </div>

    <div class="mx-auto mt-10 w-full max-w-2xl px-4 sm:px-0">
      <article class="glow-card rounded-2xl bg-ink-raised p-6 text-left sm:p-8">
        <h2 class="font-display text-xl text-paper">Sobre o curso</h2>
        <p class="mt-3 text-paper/70">{curso.descLonga}</p>
      </article>
    </div>

    <div class="mx-auto mt-10 flex w-full max-w-2xl flex-col items-center gap-4 rounded-2xl bg-ink-raised p-6 sm:p-8">
      <div class="flex items-baseline gap-2">
        <span class="font-display text-3xl text-paper">{curso.preco}</span>
        {curso.parcela && <span class="text-sm text-paper/50">{curso.parcela}</span>}
      </div>
      <a
        href={curso.href}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full max-w-xs rounded-full bg-brand-red px-6 py-3 text-center font-accent text-base text-paper transition hover:brightness-110 sm:w-auto"
      >
        {curso.preco === 'Grátis' ? 'Assistir grátis' : 'Garantir minha vaga'}
      </a>
    </div>

    {outrosCursos.length > 0 && (
      <div class="mx-auto mt-16 w-full max-w-5xl px-4 sm:px-0">
        <h2 class="text-center font-display text-2xl text-paper sm:text-3xl">Outros cursos da Academia</h2>
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {outrosCursos.map((c) => (
            <a href={`/${c.slug}`} class="glow-card flex flex-col rounded-2xl bg-ink-raised p-5 text-left transition">
              {c.badge && (
                <span class="mb-2 inline-block w-fit rounded-full bg-brand-red/20 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wide text-brand-red">
                  {c.badge}
                </span>
              )}
              <h3 class="font-semibold text-paper">{c.titulo}</h3>
              <div class="mt-4 flex items-baseline gap-2">
                <span class="font-display text-xl text-paper">{c.preco}</span>
                {c.parcela && <span class="text-xs text-paper/50">{c.parcela}</span>}
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="mx-auto mt-20 w-full max-w-5xl px-4 sm:px-0">
      <RedeFooter atual="Academia Loops Brasil" />
    </div>
  </main>

  <script>
    document.querySelectorAll<HTMLElement>('.video-facade').forEach((facade) => {
      const play = () => {
        const videoId = facade.dataset.youtubeId;
        if (!videoId) return;
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1`;
        iframe.className = 'absolute inset-0 h-full w-full';
        iframe.style.border = 'none';
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
        iframe.allowFullscreen = true;
        facade.innerHTML = '';
        facade.appendChild(iframe);
      };
      facade.addEventListener('click', play);
      facade.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          play();
        }
      });
    });
  </script>
</Base>
