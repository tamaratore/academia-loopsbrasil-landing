---
import Base from '../layouts/Base.astro';
import RedeFooter from '../components/RedeFooter.astro';

// cursos reais extraídos de edtutoriais.com.br/cursos/ em 21/07 (mesmo catálogo,
// nenhum dado inventado). Quando a Academia integrar o checkout próprio, esses
// links passam a apontar pra cá em vez de pro edtutoriais.
const cursos = [
  {
    titulo: 'Curso Kontakt 8 Pro',
    desc: 'Do zero ao profissional com o Kontakt 8. Arranjos realistas, timbres poderosos e total domínio da ferramenta.',
    preco: 'R$497',
    parcela: 'ou 12x de R$41,42',
    href: 'https://edtutoriais.com.br/k8/',
    badge: 'Mais popular',
  },
  {
    titulo: 'Produzindo do Zero',
    desc: 'Monte uma produção musical completa do zero usando loops e ferramentas dos produtores de Forró, Piseiro e Sertanejo.',
    preco: 'R$197',
    parcela: 'ou 12x de R$20,37',
    href: 'https://edtutoriais.com.br/cursoproduzindo-dozero/',
  },
  {
    titulo: 'Contakt Prático 6',
    desc: 'Aprenda a usar o Kontakt 6 na prática. Do básico ao avançado, aplicado direto na produção musical.',
    preco: 'R$87',
    parcela: 'ou 12x de R$9,00',
    href: 'https://edtutoriais.com.br/curso-kontakt-6/',
  },
  {
    titulo: 'Mixagem e Masterização',
    desc: 'Técnicas reais de mixagem e masterização para fazer sua música soar profissional.',
    preco: 'R$197',
    parcela: 'ou 12x de R$20,37',
    href: 'https://edtutoriais.com.br/cursomixagememasterizacao/',
  },
  {
    titulo: 'Guias Sertanejo',
    desc: 'Aprenda a criar os guias melódicos e arranjos harmônicos que definem o som do Sertanejo atual.',
    preco: 'R$197',
    parcela: 'ou 12x de R$20,37',
    href: 'https://edtutoriais.com.br/curso-guias/',
  },
  {
    titulo: 'Curso Loops',
    desc: 'Aprenda a usar, editar e combinar loops profissionais para criar arranjos com som de estúdio.',
    preco: 'R$67',
    parcela: 'ou 12x de R$6,93',
    href: 'https://edtutoriais.com.br/cursoloops/',
  },
  {
    titulo: 'Cakewalk DAW Gratuita',
    desc: 'Produza músicas profissionais usando o Cakewalk by BandLab, a DAW mais completa e totalmente gratuita.',
    preco: 'R$47',
    parcela: 'ou 11x de R$5,22',
    href: 'https://edtutoriais.com.br/curso-cakewalk/',
  },
  {
    titulo: 'Jornada do Sucesso',
    desc: 'Pacote completo com todos os principais cursos da ED Tutoriais. Do zero ao profissional em um só acesso.',
    preco: 'R$397',
    parcela: 'ou 12x de R$41,06',
    href: 'https://edtutoriais.com.br/curso-jornada-sucesso/',
    badge: 'Melhor custo-benefício',
  },
  {
    titulo: 'Série em Vídeo: Grave Fácil',
    desc: 'Aprenda a gravar do jeito certo com resultado profissional. Série em vídeo 100% gratuita do Eder Machado.',
    preco: 'Grátis',
    parcela: null,
    href: 'https://edtutoriais.com.br/curso-grave-facil/',
    badge: 'Gratuito',
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'Academia Loops Brasil',
  alternateName: 'ALB',
  url: 'https://academia.loopsbrasil.com.br',
};
---
<Base
  title="Academia Loops Brasil (ALB) | Cursos de Produção Fonográfica"
  description="Academia Loops Brasil. Cursos de Produção Fonográfica para quem vive a música."
  redeAtual="Academia Loops Brasil"
  structuredData={structuredData}
>
  <main class="flex min-h-screen flex-col items-center justify-center px-4 pb-16 pt-28 sm:px-6 sm:pt-24">
    <div class="mx-auto flex w-full max-w-2xl flex-col items-center text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-brand-red">ALB</p>
      <h1 class="balance mt-3 font-hero text-3xl uppercase leading-snug text-paper sm:text-4xl">
        Academia Loops Brasil
      </h1>
      <p class="mt-4 max-w-md text-lg text-paper/70">
        Cursos de Produção Fonográfica para quem vive a música.
      </p>
    </div>

    <div class="mx-auto mt-16 w-full max-w-2xl px-4 sm:px-0">
      <article class="glow-card rounded-2xl bg-ink-raised p-6 sm:p-8">
        <p class="text-paper/70">
          Em breve, a Loops Brasil contará com a Academia Loops Brasil, também
          apresentada pela sigla ALB. A nova frente educacional reunirá cursos
          de produção fonográfica, produção musical, gravação, edição,
          mixagem, instrumentos virtuais, tecnologia musical, audiovisual e
          desenvolvimento de carreira.
        </p>
        <p class="mt-4 text-paper/70">
          A Academia nasce da experiência construída pela ED Tutoriais desde
          2010 e manterá o compromisso de oferecer conhecimento prático,
          acessível e próximo da realidade de músicos, produtores e artistas.
        </p>
      </article>
    </div>

    <div class="mx-auto mt-16 w-full max-w-5xl px-4 sm:px-0">
      <h2 class="text-center font-display text-2xl text-paper sm:text-3xl">Os cursos de hoje</h2>
      <p class="mx-auto mt-3 max-w-lg text-center text-sm text-paper/60">
        Por enquanto, esses são os cursos da ED Tutoriais. Em breve eles vão
        estar integrados aqui, direto pela Academia Loops Brasil.
      </p>

      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {cursos.map((c) => (
          <a
            href={c.href}
            target="_blank"
            rel="noopener noreferrer"
            class="glow-card flex flex-col rounded-2xl bg-ink-raised p-5 transition"
          >
            {c.badge && (
              <span class="mb-2 inline-block w-fit rounded-full bg-brand-red/20 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wide text-brand-red">
                {c.badge}
              </span>
            )}
            <h3 class="font-semibold text-paper">{c.titulo}</h3>
            <p class="mt-2 text-sm text-paper/60">{c.desc}</p>
            <div class="mt-4 flex items-baseline gap-2">
              <span class="font-display text-xl text-paper">{c.preco}</span>
              {c.parcela && <span class="text-xs text-paper/50">{c.parcela}</span>}
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="mx-auto mt-20 w-full max-w-5xl px-4 sm:px-0">
      <RedeFooter atual="Academia Loops Brasil" />
    </div>
  </main>
</Base>
