---
import '../styles/global.css';
import RedeSwitcher from '../components/RedeSwitcher.astro';
import CourseNav from '../components/CourseNav.astro';
import Preloader from '../components/Preloader.astro';
import SideTabs from '../components/SideTabs.astro';

// GA4 da Academia ainda nao existe como propriedade propria (as 5 propriedades
// confirmadas em 21/07 sao edtutoriais/loopsbrasil.com.br/edtmusic/eder/proeder,
// ver memoria project_analytics_tracking_setup_20_07) - assim que Toré criar e
// passar o Measurement ID (G-XXXXXXX), colocar aqui.
const GA4_MEASUREMENT_ID = '';

interface Props {
  title: string;
  description: string;
  image?: string;
  structuredData?: Record<string, unknown>;
  redeAtual?: string;
  academiaMode?: boolean;
  cursoAtualSlug?: string;
}
const { title, description, image, structuredData, redeAtual, academiaMode, cursoAtualSlug } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).toString() : undefined;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="pt_BR" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Poppins:wght@300;400;500;600;700;800&family=Lato:wght@400;700&family=Abel&display=swap"
      rel="stylesheet"
    />

    {GA4_MEASUREMENT_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_MEASUREMENT_ID}`}></script>
        <script define:vars={{ GA4_MEASUREMENT_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', GA4_MEASUREMENT_ID);
        </script>
      </>
    )}
  </head>
  <body class="bg-black text-paper font-body antialiased">
    {academiaMode ? (
      <Preloader logo="/images/edtutoriais-logo.png" logoAlt="ED Tutoriais" />
    ) : (
      <Preloader />
    )}
    <div id="site-nav-wrap" class="nav-overlay-gradient fixed inset-x-0 top-0 z-50">
      {academiaMode ? (
        <CourseNav cursoAtualSlug={cursoAtualSlug} />
      ) : (
        redeAtual && <RedeSwitcher atual={redeAtual} />
      )}
    </div>
    {redeAtual && <SideTabs siteLabel={redeAtual} />}
    <slot />

    <script>
      const navWrap = document.getElementById('site-nav-wrap');
      if (navWrap) {
        const onScroll = () => {
          navWrap.classList.toggle('nav-solid', window.scrollY > 80);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }
    </script>
  </body>
</html>
